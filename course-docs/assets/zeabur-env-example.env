# =========================================================================
# Zeabur 環境變數標準組態範本 (.env.example)
# =========================================================================
# 說明：
# 1. 本檔案為環境變數配置範本，請拷貝此檔並改名為 `.env` 進行本地測試。
# 2. 部署至 Zeabur 時，請在服務的「Variables」設定中逐項新增以下環境變數。
# 3. ⚠️ 安全鐵律：絕不將含有真實 Key 的 `.env` 檔案提交至 Git 倉庫！
# =========================================================================

# === 核心語言模型設定 (OpenRouter) ===
# 註冊 OpenRouter 後獲取的 API Key，格式通常以 sk-or-v1- 開頭
OPENROUTER_API_KEY=sk-or-v1-your-actual-openrouter-key-here

# 預設使用的模型名稱（例如：google/gemini-2.5-pro, anthropic/claude-3.5-sonnet）
# 隨身助理建議日常對話可使用更快速便宜的 mimo-v2.5-flash
DEFAULT_MODEL=google/gemini-2.5-pro


# === Telegram 助理管道設定 (若使用 TG 機器人，請填寫此區) ===
# 透過 Telegram @BotFather 申請獲取的機器人 API Token
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ-your-tg-token

# 允許與此機器人對話的使用者 ID 清單（避免其他路人使用您的 API 額度）
# 可透過 Telegram @userinfobot 或 @myidbot 獲取您的個人 ID。多個 ID 請用逗號分隔。
TELEGRAM_ALLOWED_USERS=123456789,987654321


# === Discord 助理管道設定 (若使用 Discord 機器人，請填寫此區) ===
# 透過 Discord Developer Portal 申請獲取的 Bot Token
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# 允許與此機器人對話的 Discord 使用者 ID 清單。多個 ID 請用逗號分隔。
DISCORD_ALLOWED_USERS=123456789012345678


# === 記憶與狀態持久化設定 ===
# 機器人讀取/寫入長期記憶檔案的路徑
# ⚠️ 部署在 Zeabur 時，此路徑需與您的 Volume 掛載路徑保持一致（例如掛載在 /app/data）
MEMORY_FILE_PATH=/app/data/memory.json

# 是否在啟動時強制從指定的儲存庫同步記憶 (true/false)
MEMORY_AUTO_SYNC=true
